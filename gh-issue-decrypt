# Main
# ═══════════════════════════════════════════════════════════════════════════════

case "$MODE" in
    install)    do_install ;;
    keygen)     do_keygen ;;
    help)       do_help ;;
    encrypt)    do_encrypt ;;
    quickstart) do_quickstart ;;
    scan)       do_scan ;;
esac
