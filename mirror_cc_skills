#!/usr/bin/env bash
# mirror_cc_skills - Mirror Claude Code skills to global settings
#
# Usage:
#   mirror_cc_skills              # Mirror from current directory
#   mirror_cc_skills /path/to/project  # Mirror from specified project
#   mirror_cc_skills --sync       # Also delete skills not in source (with backup)
#   mirror_cc_skills --dry-run    # Preview what would be copied
#   mirror_cc_skills --help       # Show help
#
# By default, this ONLY copies/updates skills. It never deletes skills
# from the destination that don't exist in source. Use --sync for that.
# Targets:
#   1) ~/.claude/skills
#   2) ~/.codex/skills
#   3) ~/.gemini/skills (Gemini CLI user-scope skills)

set -euo pipefail

VERSION="1.0.0"

LOG_LEVEL="${LOG_LEVEL:-INFO}"
LOG_DIR="${LOG_DIR:-$HOME/.local/share/jsm/logs}"
LOG_FILE="${LOG_DIR}/mirror_cc_skills.log"
LOG_MAX_BYTES=$((5 * 1024 * 1024))
LOG_BACKUP_COUNT=5

init_logging() {
    mkdir -p "$LOG_DIR"
    rotate_logs
}

rotate_logs() {
    if [[ ! -f "$LOG_FILE" ]]; then
        return
    fi

    local size
    size=$(wc -c < "$LOG_FILE" | tr -d ' ')
    if [[ "$size" -lt "$LOG_MAX_BYTES" ]]; then
        return
    fi

    local idx
    for ((idx=LOG_BACKUP_COUNT; idx>=1; idx--)); do
        if [[ -f "${LOG_FILE}.${idx}" ]]; then
            if [[ "$idx" -eq "$LOG_BACKUP_COUNT" ]]; then
                rm -f "${LOG_FILE}.${idx}"
            else
                mv "${LOG_FILE}.${idx}" "${LOG_FILE}.$((idx + 1))"
            fi
        fi
    done

    mv "$LOG_FILE" "${LOG_FILE}.1"
}

level_value() {
    case "${1^^}" in
        DEBUG) echo 10 ;;
        INFO) echo 20 ;;
        WARN|WARNING) echo 30 ;;
        ERROR) echo 40 ;;
        *) echo 20 ;;
    esac
}

should_log() {
    local level_num
    level_num=$(level_value "$1")
    local min_num
    min_num=$(level_value "$LOG_LEVEL")
    [[ "$level_num" -ge "$min_num" ]]
}

write_log_line() {
    local level="$1"
    shift
    local message="$*"
    local timestamp
    timestamp=$(date -Iseconds)
    local line
    line=$(printf "%s [%-5s] mirror_cc_skills: %s" "$timestamp" "$level" "$message")
    echo "$line" >> "$LOG_FILE"
    echo "$line" >&2
}

log_debug() {
    if should_log "DEBUG"; then
        write_log_line "DEBUG" "$*"
    fi
}

# -----------------------------------------------------------------------------
# Colors (fallback when gum not available)
# -----------------------------------------------------------------------------
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

# Gum availability flag
GUM_AVAILABLE=false

# -----------------------------------------------------------------------------
# Gum auto-installation
# -----------------------------------------------------------------------------
try_install_gum() {
    local os="unknown"
    case "$(uname -s)" in
        Darwin*) os="macos" ;;
        Linux*)  os="linux" ;;
    esac

    echo -e "${BLUE}→${NC} Installing gum for prettier output..."

    case "$os" in
        macos)
            if command -v brew &> /dev/null; then
                brew install gum &>/dev/null && return 0
            fi
            ;;
        linux)
            if command -v apt-get &> /dev/null; then
                (
                    sudo mkdir -p /etc/apt/keyrings 2>/dev/null
                    curl -fsSL https://repo.charm.sh/apt/gpg.key | sudo gpg --dearmor -o /etc/apt/keyrings/charm.gpg 2>/dev/null
                    echo "deb [signed-by=/etc/apt/keyrings/charm.gpg] https://repo.charm.sh/apt/ * *" | sudo tee /etc/apt/sources.list.d/charm.list >/dev/null
                    sudo apt-get update -qq && sudo apt-get install -y -qq gum
                ) &>/dev/null && return 0
            elif command -v dnf &> /dev/null; then
                (
                    echo '[charm]
name=Charm
baseurl=https://repo.charm.sh/yum/
enabled=1
gpgcheck=1
gpgkey=https://repo.charm.sh/yum/gpg.key' | sudo tee /etc/yum.repos.d/charm.repo >/dev/null
                    sudo dnf install -y gum
                ) &>/dev/null && return 0
            elif command -v pacman &> /dev/null; then
                sudo pacman -S --noconfirm gum &>/dev/null && return 0
            fi

            # Fallback: download from GitHub releases
            local arch
            arch=$(uname -m)
            case "$arch" in
                x86_64) arch="amd64" ;;
                aarch64|arm64) arch="arm64" ;;
                *) return 1 ;;
            esac

            local tmp_dir
            tmp_dir=$(mktemp -d)
            local gum_version="0.14.5"
            local gum_url="https://github.com/charmbracelet/gum/releases/download/v${gum_version}/gum_${gum_version}_Linux_${arch}.tar.gz"

            (
                cd "$tmp_dir"
                curl -fsSL "$gum_url" -o gum.tar.gz
                tar -xzf gum.tar.gz
                sudo mv gum /usr/local/bin/gum 2>/dev/null || {
                    mkdir -p ~/.local/bin
                    mv gum ~/.local/bin/gum
                }
            ) &>/dev/null && rm -rf "$tmp_dir" && return 0

            rm -rf "$tmp_dir"
            ;;
    esac

    return 1
}

check_gum() {
    if command -v gum &> /dev/null; then
        GUM_AVAILABLE=true
        return 0
    fi

    # Try to install gum
    if try_install_gum; then
        # Add ~/.local/bin to PATH if gum was installed there
        if [[ -x "${HOME}/.local/bin/gum" && ":$PATH:" != *":${HOME}/.local/bin:"* ]]; then
            export PATH="${HOME}/.local/bin:${PATH}"
        fi
        if command -v gum &> /dev/null; then
            GUM_AVAILABLE=true
            return 0
        fi
    fi

    return 1
}

# -----------------------------------------------------------------------------
# Styled output functions
# -----------------------------------------------------------------------------
print_banner() {
    if [[ "$GUM_AVAILABLE" == "true" ]]; then
        gum style \
            --border rounded \
            --border-foreground 212 \
            --padding "0 2" \
            --margin "1 0" \
            --bold \
            "🔄 mirror_cc_skills v${VERSION}" \
            "Sync skills to Claude/Codex/Gemini"
    else
        echo -e "\n${BOLD}${MAGENTA}╭──────────────────────────────────────────╮${NC}"
        echo -e "${BOLD}${MAGENTA}│${NC}  ${BOLD}🔄 mirror_cc_skills v${VERSION}${NC}               ${BOLD}${MAGENTA}│${NC}"
        echo -e "${BOLD}${MAGENTA}│${NC}  ${DIM}Sync skills to Claude/Codex/Gemini${NC}    ${BOLD}${MAGENTA}│${NC}"
        echo -e "${BOLD}${MAGENTA}╰──────────────────────────────────────────╯${NC}\n"
    fi
}

log_info() {
    if should_log "INFO"; then
        write_log_line "INFO" "$*"
    fi
}

log_warn() {
    if should_log "WARN"; then
        write_log_line "WARN" "$*"
    fi
}

log_error() {
    if should_log "ERROR"; then
        write_log_line "ERROR" "$*"
    fi
}

log_success() {
    if should_log "INFO"; then
        write_log_line "INFO" "$*"
    fi
}

log_step() {
    if should_log "INFO"; then
        write_log_line "INFO" "$*"
    fi
}

hash_command() {
    if command -v sha256sum &> /dev/null; then
        sha256sum "$@"
    else
        shasum -a 256 "$@"
    fi
}

count_files() {
    find "$1" -type f 2>/dev/null | wc -l | tr -d ' '
}

dir_hash() {
    local dir="$1"
    if [[ ! -d "$dir" ]]; then
        echo ""
        return
    fi

    if [[ -z "$(find "$dir" -type f -print -quit 2>/dev/null)" ]]; then
        echo "empty"
        return
    fi

    find "$dir" -type f -print 2>/dev/null | sort | while read -r file; do
        hash_command "$file"
    done | hash_command | awk '{print $1}'
}

dir_latest_mtime() {
    local dir="$1"
    if [[ ! -d "$dir" ]]; then
        echo 0
        return
    fi

    if [[ -z "$(find "$dir" -type f -print -quit 2>/dev/null)" ]]; then
        echo 0
        return
    fi

    local latest=""
    if stat -c %Y "$dir" &> /dev/null; then
        latest=$(find "$dir" -type f -print 2>/dev/null | while read -r file; do
            stat -c %Y "$file"
        done | sort -n | tail -1)
    else
        latest=$(find "$dir" -type f -print 2>/dev/null | while read -r file; do
            stat -f %m "$file"
        done | sort -n | tail -1)
    fi

    if [[ -z "$latest" ]]; then
        echo 0
        return
    fi

    printf "%.0f\n" "$latest"
}

sync_skill() {
    local skill="$1"
    local rsync_opts="$2"
    local skill_name
    skill_name=$(basename "$skill")

    log_debug "Processing skill: $skill_name"
    log_debug "  Source: $skill"
    log_debug "  Files: $(count_files "$skill")"

    local target="$DEST_DIR/$skill_name"
    local canonical_hash
    canonical_hash=$(dir_hash "$skill")
    local global_hash=""
    if [[ -d "$target" ]]; then
        global_hash=$(dir_hash "$target")
    fi

    local source_mtime
    source_mtime=$(dir_latest_mtime "$skill")
    local dest_mtime
    dest_mtime=$(dir_latest_mtime "$target")

    if [[ -d "$target" && "$canonical_hash" != "$global_hash" && "$dest_mtime" -gt "$source_mtime" && "$FORCE" == "false" ]]; then
        log_error "CONFLICT: $skill_name has local modifications"
        log_error "  Canonical hash: $canonical_hash"
        log_error "  Global hash: $global_hash"
        log_error "  Action: Skipping (use --force to overwrite)"
        skipped_count=$((skipped_count + 1))
        return
    fi

    local rsync_output=""
    if rsync_output=$(rsync $rsync_opts "$skill/" "$target/" 2>&1); then
        if [[ -n "$rsync_output" ]]; then
            log_debug "rsync output:\n$rsync_output"
        else
            log_debug "rsync output: (none)"
        fi
        log_info "✓ Synced: $skill_name"
        synced_count=$((synced_count + 1))
    else
        if [[ -n "$rsync_output" ]]; then
            log_debug "rsync output:\n$rsync_output"
        else
            log_debug "rsync output: (none)"
        fi
        log_error "✗ Failed: $skill_name"
        error_count=$((error_count + 1))
    fi
}

show_help() {
    check_gum || true

    if [[ "$GUM_AVAILABLE" == "true" ]]; then
        gum style \
            --border rounded \
            --border-foreground 212 \
            --padding "0 2" \
            --margin "1 0" \
            --bold \
            "🔄 mirror_cc_skills v${VERSION}"

        echo ""
        gum style --foreground 214 --bold "SYNOPSIS"
        echo "  mirror_cc_skills [OPTIONS] [PROJECT_DIR]"
        echo ""

        gum style --foreground 214 --bold "DESCRIPTION"
        gum style --padding "0 2" "Mirror Claude Code skills from a project's .claude/skills/
directory to your global ~/.claude/skills/ directory, then mirror to
Codex and Gemini skill directories."
        echo ""

        gum style --foreground 214 --bold "OPTIONS"
        gum style --foreground 82 "  --dry-run, -n"
        gum style --foreground 245 "      Preview changes without modifying anything"
        gum style --foreground 82 "  --sync"
        gum style --foreground 245 "      Delete skills not in source (creates backup first)"
        gum style --foreground 82 "  --force"
        gum style --foreground 245 "      Overwrite conflicts when global skills differ"
        gum style --foreground 82 "  --help, -h"
        gum style --foreground 245 "      Show this help message"
        echo ""

        gum style --foreground 214 --bold "ENVIRONMENT"
        gum style --foreground 245 "  LOG_LEVEL  (DEBUG, INFO, WARN, ERROR)  Default: INFO"
        gum style --foreground 245 "  LOG_DIR    Log directory (default: ~/.local/share/jsm/logs)"
        echo ""

        gum style --foreground 214 --bold "SAFETY"
        gum style --padding "0 2" "By default, only adds/updates skills. Never deletes.
Use --sync to fully synchronize (backs up first)."
        echo ""

        gum style --foreground 214 --bold "EXAMPLES"
        gum style --foreground 39 "  # Mirror from current project"
        echo "  mirror_cc_skills"
        echo ""
        gum style --foreground 39 "  # Mirror from specific project"
        echo "  mirror_cc_skills /data/projects/my-skills"
        echo ""
        gum style --foreground 39 "  # Preview what would change"
        echo "  mirror_cc_skills --dry-run"
    else
        echo -e "${BOLD}mirror_cc_skills${NC} v${VERSION}"
        echo ""
        echo "Mirror Claude Code skills to global Claude/Codex/Gemini skill dirs"
        echo ""
        echo "USAGE:"
        echo "  mirror_cc_skills [OPTIONS] [PROJECT_DIR]"
        echo ""
        echo "OPTIONS:"
        echo "  --dry-run, -n   Preview changes without modifying anything"
        echo "  --sync          Delete skills not in source (creates backup first)"
        echo "  --force         Overwrite conflicts when global skills differ"
        echo "  --help, -h      Show this help message"
        echo ""
        echo "ENVIRONMENT:"
        echo "  LOG_LEVEL       DEBUG, INFO, WARN, ERROR (default: INFO)"
        echo "  LOG_DIR         Log directory (default: ~/.local/share/jsm/logs)"
        echo ""
        echo "EXAMPLES:"
        echo "  mirror_cc_skills                        # from current directory"
        echo "  mirror_cc_skills /path/to/project       # from specific project"
        echo "  mirror_cc_skills --dry-run              # preview changes"
    fi
}

show_skills_list() {
    local dir="$1"
    local skills
    skills=$(ls -1 "$dir" 2>/dev/null)

    if [[ "$GUM_AVAILABLE" == "true" ]]; then
        gum style --foreground 214 --bold "Global skills:"
        if [[ -n "$skills" ]]; then
            echo "$skills" | while read -r skill; do
                [[ -n "$skill" ]] && gum style --foreground 82 "  ✓ $skill"
            done
        else
            gum style --foreground 245 "  (none)"
        fi
    else
        echo -e "${BOLD}Global skills:${NC}"
        if [[ -n "$skills" ]]; then
            echo "$skills" | sed 's/^/  ✓ /'
        else
            echo -e "  ${DIM}(none)${NC}"
        fi
    fi
}

# -----------------------------------------------------------------------------
# Main
# -----------------------------------------------------------------------------
main() {
    init_logging
    check_gum || true

    START_TS=$(date +%s)
    SYNC_MODE=false
    DRY_RUN=false
    FORCE=false
    PROJECT_DIR="."

    # Parse arguments
    for arg in "$@"; do
        case "$arg" in
            --help|-h)
                show_help
                exit 0
                ;;
            --sync)
                SYNC_MODE=true
                ;;
            --force)
                FORCE=true
                ;;
            --dry-run|-n)
                DRY_RUN=true
                ;;
            -*)
                log_error "Unknown option: $arg"
                echo "Usage: mirror_cc_skills [--sync] [--force] [--dry-run] [project_dir]" >&2
                exit 1
                ;;
            *)
                PROJECT_DIR="$arg"
                ;;
        esac
    done

    SOURCE_DIR="$PROJECT_DIR/.claude/skills"
    DEST_DIR="$HOME/.claude/skills"
    CODEX_SKILLS_DIR="${CODEX_HOME:-$HOME/.codex}/skills"
    GEMINI_SKILLS_DIR="$HOME/.gemini/skills"

    # Validate source exists
    if [[ ! -d "$SOURCE_DIR" ]]; then
        log_error "No skills directory found at $SOURCE_DIR"
        exit 1
    fi

    # Ensure destination exists
    mkdir -p "$DEST_DIR"

    SKILL_DIRS=()
    while IFS= read -r skill_dir; do
        [[ -n "$skill_dir" ]] && SKILL_DIRS+=("$skill_dir")
    done < <(find "$SOURCE_DIR" -maxdepth 1 -mindepth 1 -type d 2>/dev/null | sort)

    SKILL_COUNT=${#SKILL_DIRS[@]}

    print_banner

    log_info "=== mirror_cc_skills started ==="
    log_info "Timestamp: $(date -Iseconds)"
    log_info "Source: $SOURCE_DIR"
    log_info "Target 1: $DEST_DIR"
    log_info "Target 2: $CODEX_SKILLS_DIR"
    log_info "Target 3: $GEMINI_SKILLS_DIR"
    log_info "Options: $*"
    log_debug "LOG_LEVEL=$LOG_LEVEL SYNC_MODE=$SYNC_MODE DRY_RUN=$DRY_RUN FORCE=$FORCE"

    if $DRY_RUN; then
        log_info "[DRY RUN] Would mirror $SKILL_COUNT skills"
        log_step "Source: $SOURCE_DIR"
        log_step "Dest:   $DEST_DIR"
    else
        log_info "Mirroring $SKILL_COUNT skills"
        log_step "Source: $SOURCE_DIR"
        log_step "Dest:   $DEST_DIR"
    fi

    echo ""

    RSYNC_OPTS="-av"
    $DRY_RUN && RSYNC_OPTS="-avn"
    RSYNC_DELETE_OPTS="$RSYNC_OPTS --delete"

    synced_count=0
    skipped_count=0
    error_count=0

    if $SYNC_MODE; then
        log_warn "--sync mode: Skills not in source will be DELETED"

        if ! $DRY_RUN; then
            BACKUP_DIR="$DEST_DIR.backup.$(date +%Y%m%d_%H%M%S)"
            log_step "Creating backup at $BACKUP_DIR"
            cp -r "$DEST_DIR" "$BACKUP_DIR"
            log_success "Backup created"
        fi
    fi

    if [[ "$SKILL_COUNT" -eq 0 ]]; then
        log_warn "No skills found in $SOURCE_DIR"
    fi

    for skill in "${SKILL_DIRS[@]}"; do
        if $SYNC_MODE; then
            sync_skill "$skill" "$RSYNC_DELETE_OPTS"
        else
            sync_skill "$skill" "$RSYNC_OPTS"
        fi
    done

    if $SYNC_MODE; then
        delete_output=""
        if delete_output=$(rsync $RSYNC_DELETE_OPTS "$SOURCE_DIR/" "$DEST_DIR/" 2>&1); then
            if [[ -n "$delete_output" ]]; then
                log_debug "rsync delete pass output:\n$delete_output"
            else
                log_debug "rsync delete pass output: (none)"
            fi
        else
            log_error "Delete pass failed"
            if [[ -n "$delete_output" ]]; then
                log_debug "rsync delete pass output:\n$delete_output"
            else
                log_debug "rsync delete pass output: (none)"
            fi
            error_count=$((error_count + 1))
        fi
    fi

    echo ""

    if $DRY_RUN; then
        log_info "[DRY RUN] No changes made"
    else
        log_success "Skills mirrored to ~/.claude/skills"
    fi

    echo ""
    show_skills_list "$DEST_DIR"

    # Mirror to Codex skills directory
    if $DRY_RUN; then
        log_info "[DRY RUN] Would also mirror to $CODEX_SKILLS_DIR"
    else
        mkdir -p "$CODEX_SKILLS_DIR"
        codex_output=""
        if codex_output=$(rsync -a "$DEST_DIR/" "$CODEX_SKILLS_DIR/" 2>&1); then
            if [[ -n "$codex_output" ]]; then
                log_debug "rsync codex output:\n$codex_output"
            else
                log_debug "rsync codex output: (none)"
            fi
            log_success "Skills mirrored to $CODEX_SKILLS_DIR"
        else
            log_error "Failed to mirror to $CODEX_SKILLS_DIR"
            if [[ -n "$codex_output" ]]; then
                log_debug "rsync codex output:\n$codex_output"
            else
                log_debug "rsync codex output: (none)"
            fi
            error_count=$((error_count + 1))
        fi
    fi

    # Mirror to Gemini skills directory
    if $DRY_RUN; then
        log_info "[DRY RUN] Would also mirror to $GEMINI_SKILLS_DIR"
    else
        mkdir -p "$GEMINI_SKILLS_DIR"
        gemini_output=""
        if gemini_output=$(rsync -a "$DEST_DIR/" "$GEMINI_SKILLS_DIR/" 2>&1); then
            if [[ -n "$gemini_output" ]]; then
                log_debug "rsync gemini output:\n$gemini_output"
            else
                log_debug "rsync gemini output: (none)"
            fi
            log_success "Skills mirrored to $GEMINI_SKILLS_DIR"
        else
            log_error "Failed to mirror to $GEMINI_SKILLS_DIR"
            if [[ -n "$gemini_output" ]]; then
                log_debug "rsync gemini output:\n$gemini_output"
            else
                log_debug "rsync gemini output: (none)"
            fi
            error_count=$((error_count + 1))
        fi
    fi

    duration=$(( $(date +%s) - START_TS ))
    log_info "=== Sync Summary ==="
    log_info "Skills synced: $synced_count"
    log_info "Skills skipped: $skipped_count"
    log_info "Errors: $error_count"
    log_info "Duration: ${duration}s"
    log_info "=== mirror_cc_skills completed ==="
}

main "$@"
